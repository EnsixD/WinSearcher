<Window x:Class="WinSearcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WinSearcher"
        Width="580"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        FocusVisualStyle="{x:Null}">

    <Window.Resources>

        <!-- ── Animations ─────────────────────────────────────────────── -->
        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetName="RootBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="SlideTransform"
                             Storyboard.TargetProperty="Y"
                             From="-10" To="0" Duration="0:0:0.18">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="FadeOutStoryboard">
            <DoubleAnimation Storyboard.TargetName="RootBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.09"/>
        </Storyboard>

        <!-- ── Search TextBox ─────────────────────────────────────────── -->
        <Style x:Key="SearchBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Background"        Value="Transparent"/>
            <Setter Property="Foreground"        Value="#EFEFEF"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="FontSize"          Value="15"/>
            <Setter Property="FontFamily"        Value="Segoe UI"/>
            <Setter Property="FontWeight"        Value="Light"/>
            <Setter Property="CaretBrush"        Value="#EFEFEF"/>
            <Setter Property="SelectionBrush"    Value="#333333"/>
            <Setter Property="FocusVisualStyle"  Value="{x:Null}"/>
            <Setter Property="Padding"           Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Grid VerticalAlignment="Center">
                            <TextBlock x:Name="Placeholder"
                                       Text="Search apps, files, folders..."
                                       Foreground="#383838"
                                       FontSize="15"
                                       FontFamily="Segoe UI"
                                       FontWeight="Light"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Visibility="Collapsed"/>
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="False"
                                          VerticalAlignment="Center"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ── Root animation target ──────────────────────────────────────── -->
    <Border x:Name="RootBorder" Opacity="0">
        <Border.RenderTransform>
            <TranslateTransform x:Name="SlideTransform" Y="-10"/>
        </Border.RenderTransform>

        <!-- Outer shadow padding -->
        <Border Margin="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" ShadowDepth="8"
                                  Opacity="0.85" Color="#000000" Direction="270"/>
            </Border.Effect>

            <!-- Main card -->
            <Border x:Name="MainBorder"
                    CornerRadius="12"
                    Background="#0A0A0A"
                    BorderBrush="#1E1E1E"
                    BorderThickness="1">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- search bar -->
                        <RowDefinition Height="Auto"/>  <!-- divider -->
                        <RowDefinition Height="Auto"/>  <!-- section header -->
                        <RowDefinition Height="Auto"/>  <!-- results / empty / loading -->
                    </Grid.RowDefinitions>

                    <!-- ── Search bar row ──────────────────────────────── -->
                    <Border Grid.Row="0"
                            Margin="10,10,10,10"
                            CornerRadius="8"
                            Background="#111111"
                            BorderBrush="#1E1E1E"
                            BorderThickness="1"
                            MouseLeftButtonDown="SearchBar_MouseLeftButtonDown">
                        <Grid Height="44">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Search icon -->
                            <Viewbox Grid.Column="0"
                                     Width="16" Height="16"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     IsHitTestVisible="False">
                                <Canvas Width="24" Height="24">
                                    <Ellipse Canvas.Left="2" Canvas.Top="2"
                                             Width="14" Height="14"
                                             Stroke="#3A3A3A" StrokeThickness="2"
                                             Fill="Transparent"/>
                                    <Line X1="14" Y1="14" X2="22" Y2="22"
                                          Stroke="#3A3A3A" StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"/>
                                </Canvas>
                            </Viewbox>

                            <!-- Input -->
                            <TextBox x:Name="SearchBox"
                                     Grid.Column="1"
                                     Style="{StaticResource SearchBoxStyle}"
                                     VerticalAlignment="Center"
                                     TextChanged="SearchBox_TextChanged"
                                     PreviewKeyDown="SearchBox_PreviewKeyDown"/>

                            <!-- Clear button -->
                            <Button x:Name="ClearButton"
                                    Grid.Column="2"
                                    Margin="0,0,10,0"
                                    Cursor="Hand"
                                    Visibility="Collapsed"
                                    Click="ClearButton_Click"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    VerticalAlignment="Center"
                                    FocusVisualStyle="{x:Null}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" CornerRadius="12"
                                                Background="Transparent"
                                                Width="24" Height="24">
                                            <TextBlock Text="✕"
                                                       Foreground="#404040"
                                                       FontSize="10"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#1E1E1E"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- ── Divider (shown only when list is visible) ───── -->
                    <Border x:Name="Divider"
                            Grid.Row="1"
                            Height="1"
                            Margin="10,0"
                            Background="#141414"
                            Visibility="Collapsed"/>

                    <!-- ── Section label ───────────────────────────────── -->
                    <TextBlock x:Name="SectionHeader"
                               Grid.Row="2"
                               Margin="16,10,0,4"
                               Text="RECENT"
                               Foreground="#2C2C2C"
                               FontSize="9"
                               FontFamily="Segoe UI"
                               FontWeight="SemiBold"
                               Visibility="Collapsed"/>

                    <!-- ── Results list ────────────────────────────────── -->
                    <ListBox x:Name="ResultsList"
                             Grid.Row="3"
                             Style="{StaticResource ResultsListStyle}"
                             Margin="0,0,0,6"
                             MaxHeight="360"
                             PreviewKeyDown="ResultsList_PreviewKeyDown"
                             MouseLeftButtonUp="ResultsList_MouseLeftButtonUp"
                             SelectionChanged="ResultsList_SelectionChanged"
                             Visibility="Collapsed">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="46" Margin="4,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Icon container -->
                                    <Border Grid.Column="0"
                                            Width="32" Height="32"
                                            CornerRadius="7"
                                            Background="#161616"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                        <Image Source="{Binding Icon}"
                                               Width="20" Height="20"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>

                                    <!-- Name + subtitle -->
                                    <StackPanel Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Margin="10,0,8,0">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="#E0E0E0"
                                                   FontSize="13.5"
                                                   FontFamily="Segoe UI"
                                                   FontWeight="Regular"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Description}"
                                                   Foreground="#333333"
                                                   FontSize="10"
                                                   FontFamily="Segoe UI"
                                                   Margin="0,2,0,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <!-- Type pill -->
                                    <Border Grid.Column="2"
                                            Margin="0,0,6,0"
                                            Padding="6,3"
                                            CornerRadius="4"
                                            VerticalAlignment="Center"
                                            Background="#0F0F0F"
                                            BorderBrush="#1E1E1E"
                                            BorderThickness="1">
                                        <TextBlock Text="{Binding TypeLabel}"
                                                   Foreground="#2E2E2E"
                                                   FontSize="9"
                                                   FontFamily="Segoe UI"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- ── Empty state ─────────────────────────────────── -->
                    <Border x:Name="EmptyState"
                            Grid.Row="3"
                            Padding="16,20"
                            Visibility="Collapsed">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="No results"
                                       Foreground="#252525"
                                       FontSize="13"
                                       FontFamily="Segoe UI"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="EmptyStateSubtext"
                                       Foreground="#1E1E1E"
                                       FontSize="10"
                                       FontFamily="Segoe UI"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- ── Loading indicator ───────────────────────────── -->
                    <Border x:Name="LoadingState"
                            Grid.Row="3"
                            Padding="16,14"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Ellipse Width="4" Height="4" Fill="#2A2A2A" Margin="3,0"/>
                            <Ellipse Width="4" Height="4" Fill="#2A2A2A" Margin="3,0" Opacity="0.55"/>
                            <Ellipse Width="4" Height="4" Fill="#2A2A2A" Margin="3,0" Opacity="0.25"/>
                        </StackPanel>
                    </Border>

                </Grid>
            </Border>
        </Border>
    </Border>
</Window>
